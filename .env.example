# ============================================================================
# Claude Scaffolder — environment configuration
# ============================================================================
# Copy this file to `.env` and edit as needed. docker-compose reads `.env`
# automatically. For local (non-Docker) runs, `export` these in your shell.

# ----------------------------------------------------------------------------
# LLM endpoint
# ----------------------------------------------------------------------------
# Any OpenAI-compatible /v1 endpoint works: Ollama, LM Studio, vLLM, llama.cpp, OpenAI itself.

# Default assumes Ollama running on your host at the default port.
# - Running backend in Docker on Windows/Mac: use host.docker.internal
# - Running backend in Docker on Linux: use your host IP or run with --network=host
# - Running backend locally (uvicorn): use localhost
LLM_BASE_URL=http://host.docker.internal:11434/v1
# LLM_BASE_URL=http://localhost:11434/v1          # local dev without Docker
# LLM_BASE_URL=http://localhost:1234/v1           # LM Studio
# LLM_BASE_URL=https://api.openai.com/v1          # OpenAI (needs real key below)

# Model name. For Ollama, this is the tag you `ollama pull`ed.
# Recommended for this use case (structured output + code understanding):
#   qwen2.5-coder:14b     balanced, great at JSON
#   qwen2.5-coder:7b      lighter, still solid
#   deepseek-coder-v2:16b heavier but strong reasoner
#   llama3.1:8b           general purpose fallback
LLM_MODEL=qwen2.5-coder:7b

# API key. Ollama ignores this but the OpenAI-compat spec requires a field.
# For OpenAI / cloud endpoints, put your real key here.
LLM_API_KEY=ollama

# Request timeout in seconds. Bump higher for slow hardware or large models.
LLM_TIMEOUT=120

# Sampling temperature. Keep low (0.1–0.4) for structured output; higher (0.6–0.8)
# for creative fields like skill bodies if you want more variety.
LLM_TEMPERATURE=0.3
