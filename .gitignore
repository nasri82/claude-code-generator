# ============================================================================
# Environment / secrets
# ============================================================================
.env
.env.local
.env.*.local

# ============================================================================
# Claude Code local state
# ============================================================================
# Per-user / per-machine permissions + overrides that shouldn't be in VCS.
.claude/settings.local.json
# The project-level .claude/settings.json IS typically committed —
# only the *.local.json variant is user-specific.

